    execution_result = await self.execute_hypothesis_test(hypothesis, state)
    await self.judge_hypothesis(execution_result, state)
Each hypothesis is completely independent — different file names (hypothesis_1_*.png, hypothesis_2_*.png), different commands, different code, different judge summaries.

Proposed:

async def run_single_hypothesis(hypothesis, state):
    # Give each hypothesis its own kernel to avoid conflicts
    local_agent = CodeAgent()
    local_state = {**state, "history": []}
    execution_result = await self.execute_hypothesis_test(hypothesis, local_state, agent=local_agent)
    await self.judge_hypothesis(execution_result, local_state)
    local_agent.executor.cleanup()
await asyncio.gather(*[
    run_single_hypothesis(h, state) for h in hypotheses
